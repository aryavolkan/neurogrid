# GDScript lint configuration (gdtoolkit)
# See: https://github.com/Scony/godot-gdscript-toolkit/wiki/3.-Linter

# Naming conventions
class-name: "([A-Z][a-z0-9]*)+"
sub-class-name: "_?([A-Z][a-z0-9]*)+"
class-variable-name: "_?[a-zA-Z][a-zA-Z0-9]*(_[a-zA-Z0-9]+)*"
class-load-variable-name: "(([A-Z][a-z0-9]*)+|_?[a-z][a-z0-9]*(_[a-z0-9]+)*)"
function-name: "(_on_([A-Z][a-z0-9]*)+(_[a-z0-9]+)*|_?[a-z][a-z0-9]*(_[a-z0-9]+)*)"
function-variable-name: "_?[a-z][a-z0-9]*(_[a-z0-9]+)*"
function-argument-name: "_?[a-z][a-z0-9]*(_[a-z0-9]+)*"
function-preload-variable-name: "([A-Z][a-z0-9]*)+"
signal-name: "[a-z][a-z0-9]*(_[a-z0-9]+)*"
constant-name: "[A-Z][A-Z0-9]*(_[A-Z0-9]+)*"
load-constant-name: "(([A-Z][a-z0-9]*)+|[A-Z][A-Z0-9]*(_[A-Z0-9]+)*)"
enum-name: "([A-Z][a-z0-9]*)+"
enum-element-name: "[A-Z][A-Z0-9]*(_[A-Z0-9]+)*"
loop-variable-name: "_?[a-z][a-z0-9]*(_[a-z0-9]+)*"

# Limits
max-line-length: 120
function-arguments-number: 10
max-returns: 15
max-public-methods: 30

# Disabled rules:
# - class-definitions-order: too disruptive for existing codebase (GameConfig mixes consts/vars)
disable:
  - "class-definitions-order"
